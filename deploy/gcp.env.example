# =============================================================================
# DocIA — déploiement GCP (copier vers .env sur la VM)
# =============================================================================

OPENAI_API_KEY=sk-votre-cle-api
POSTGRES_PASSWORD=mot-de-passe-fort-unique

POSTGRES_USER=docia
POSTGRES_DB=docia_fr
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_PROVIDER=openai
FAST_MODE=true

APP_PORT=8501
RUN_PG_INIT=true
AUTO_PG_INGEST=false

# HTTPS (profil Caddy) — après configuration DNS
DOMAIN=docia.votre-domaine.fr
ACME_EMAIL=admin@votre-domaine.fr

# GCP — région recommandée : europe-west9 (Paris)
# VM type : e2-medium (2 vCPU, 4 Go RAM)
