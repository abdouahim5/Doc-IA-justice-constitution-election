# Secrets Streamlit Community Cloud — NE PAS COMMITTER
# Copiez ce modèle dans le tableau "Secrets" du dashboard Streamlit Cloud
# https://share.streamlit.io → votre app → Settings → Secrets

OPENAI_API_KEY = "sk-votre-cle-api"
LLM_PROVIDER = "openai"
OPENAI_MODEL = "gpt-4o-mini"
EMBEDDING_PROVIDER = "openai"
FAST_MODE = "true"

# PostgreSQL externe (Neon, Supabase…) avec pgvector — obligatoire pour le multi-agent
DATABASE_URL = "postgresql+psycopg://user:password@ep-xxx.eu-west-1.aws.neon.tech/docia_fr?sslmode=require"
