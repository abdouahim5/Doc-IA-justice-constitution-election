# =============================================================================
# Agent IA RAG — fichier de configuration exemple
# Copiez ce fichier vers .env et adaptez les valeurs
#   copy .env.example .env
# =============================================================================

# --- Fournisseur LLM : "openai" ou "ollama" ---
LLM_PROVIDER=openai

# --- OpenAI (si LLM_PROVIDER=openai) ---
OPENAI_API_KEY=sk-votre-cle-api
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=600

# --- Ollama (si LLM_PROVIDER=ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_NUM_PREDICT=350
OLLAMA_NUM_CTX=2048

# --- Embeddings : "openai", "local" (HuggingFace) ou "tfidf" (hors ligne) ---
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# --- Parametres RAG ---
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K_RESULTS=6
RETRIEVAL_CANDIDATES=15
SCORE_THRESHOLD=0.12
MIN_RELEVANCE_SCORE=0.18
TEMPERATURE=0
FAST_MODE=true

# --- Conversation ---
CONVERSATION_HISTORY_TURNS=6

# --- Chemins ---
DOCUMENTS_DIR=./data/documents
VECTOR_STORE_DIR=./data/vectorstore

# --- PostgreSQL (multi-agent Constitution & Élections) ---
# docker compose up -d
DATABASE_URL=postgresql+psycopg://docia:docia_secret@localhost:5433/docia_fr
