# =============================================================================
# DocIA — configuration production (copier vers .env sur le VPS)
#   cp .env.production.example .env
# =============================================================================

# --- Secrets obligatoires ---
OPENAI_API_KEY=sk-votre-cle-api
POSTGRES_PASSWORD=changez-moi-mot-de-passe-fort

# --- PostgreSQL (interne Docker) ---
POSTGRES_USER=docia
POSTGRES_DB=docia_fr
# DATABASE_URL est injectée automatiquement par docker-compose.prod.yml

# --- LLM ---
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=400
EMBEDDING_PROVIDER=openai

# --- Performance ---
FAST_MODE=true
MIN_RELEVANCE_SCORE=0.18
CONVERSATION_HISTORY_TURNS=6

# --- Démarrage conteneur ---
RUN_PG_INIT=true
AUTO_PG_INGEST=false
AUTO_CHROMA_INDEX=false
DB_WAIT_SECONDS=120

# --- Port exposé (sans Caddy) ---
APP_PORT=8501

# --- HTTPS avec Caddy (profil --profile https) ---
DOMAIN=votre-domaine.fr
ACME_EMAIL=admin@votre-domaine.fr

# --- Chemins (dans le conteneur — ne pas modifier) ---
DOCUMENTS_DIR=/app/data/documents
VECTOR_STORE_DIR=/app/data/vectorstore
